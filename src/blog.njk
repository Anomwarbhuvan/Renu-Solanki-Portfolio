---
layout: base.njk
title: "Blogs"
description: "Browse all blogs and writings by Renu Solanki. Fiction, reflections, and explorations."
permalink: /blog/
---

<div class="page-header" style="border-bottom: none;">
  <div class="container">
    <div class="section-label">The Archive</div>
    <h1 class="section-title">All Blogs</h1>
    <p class="section-desc">Every word, every story, every reflection — collected in one place.</p>
  </div>
</div>

{% include "category-nav.njk" %}

<section class="blog-section">
  <div class="container">
    <div class="stories-grid">
      {% for story in collections.blogs | reverse %}
        {% set grad = story.data.gradient if story.data.gradient else ((loop.index0 % 6) + 1) %}
        <a href="{{ story.url }}" class="story-card" data-category="{{ story.data.category }}">
          <div class="story-thumb {% if not story.data.thumbnail %}story-thumb-gradient-{{ grad }}{% endif %}">
            {% if story.data.thumbnail %}<img src="{{ story.data.thumbnail }}" alt="{{ story.data.title }}" class="story-thumb-img">{% endif %}
            <span class="story-category">{{ story.data.category | categoryLabel(categories) }}</span>
            {% if not story.data.thumbnail %}<span class="story-thumb-icon">{{ story.data.icon | default("✍️") }}</span>{% endif %}
          </div>
          <div class="story-content">
            <div class="story-date">{{ story.date | dateFormat }}</div>
            <h3 class="story-title">{{ story.data.title }}</h3>
            <p class="story-excerpt">{{ story.data.excerpt }}</p>
            <span class="story-read-more">Read Blog</span>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

<section class="newsletter">
  <div class="container">
    <div class="newsletter-inner">
      <div class="newsletter-icon">&#9993;</div>
      <div class="section-label">Stay Connected</div>
      <h2 class="section-title">Letters to Your Inbox</h2>
      <p class="section-desc">Subscribe for weekly stories and writing inspiration every Tuesday.</p>
      <form class="newsletter-form">
        <input type="email" class="newsletter-input" placeholder="Enter your email address" required>
        <button type="submit" class="newsletter-btn">Subscribe</button>
      </form>
      <p class="newsletter-note">No spam, ever. Unsubscribe anytime.</p>
    </div>
  </div>
</section>
